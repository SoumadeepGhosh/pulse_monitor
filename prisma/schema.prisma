generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int               @id @default(autoincrement())
  email           String            @unique
  name            String?
  createdAt       DateTime          @default(now())
  password        String?
  updatedAt       DateTime          @updatedAt
  image           String?
  accounts        Account[]
  monitors        Monitor[]
  successCriteria SuccessCriteria[]
  notifications   Notification[]
  emailRecipients EmailRecipient[]
}

model Account {
  id                Int    @id @default(autoincrement())
  provider          String
  providerAccountId String
  userId            Int
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Monitor {
  id              Int                      @id @default(autoincrement())
  userId          Int
  name            String
  url             String                   @unique
  method          HttpMethod
  status          MonitorStatus            @default(UNKNOWN)
  intervalMinutes Int
  isActive        Boolean                  @default(true)
  lastCheckedAt   DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  checkResults    CheckResult[]
  criteria        MonitorSuccessCriteria[]
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailRecipients MonitorEmailRecipient[]

  @@index([userId])
}

model CheckResult {
  id           Int      @id @default(autoincrement())
  monitorId    Int
  success      Boolean
  statusCode   Int?
  responseTime Int?
  errorMessage String?
  checkedAt    DateTime @default(now())
  monitor      Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([checkedAt])
}

model Notification {
  id           Int              @id @default(autoincrement())
  userId       Int
  message      String
  type         NotificationType
  isRead       Boolean          @default(false)
  redirectPath String?
  readAt       DateTime?
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SuccessCriteria {
  id            Int                      @id @default(autoincrement())
  userId        Int
  name          String
  type          CriteriaType
  jsonPath      String?
  operator      Operator
  expectedValue String
  monitors      MonitorSuccessCriteria[]
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
}

model MonitorSuccessCriteria {
  monitorId         Int
  successCriteriaId Int

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  successCriteria SuccessCriteria @relation(fields: [successCriteriaId], references: [id])

  assignedAt DateTime @default(now())

  @@id([monitorId, successCriteriaId])
}

model EmailRecipient {
  id Int @id @default(autoincrement())

  userId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  name String

  email String

  consecutiveThreshold Int @default(3)

  monitors MonitorEmailRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, email])
  @@index([userId])
}

model MonitorEmailRecipient {
  monitorId Int

  recipientId Int

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  recipient EmailRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  previousStatus MonitorStatus @default(UNKNOWN)


  assignedAt DateTime @default(now())

  @@id([monitorId, recipientId])

  @@index([monitorId])

  @@index([recipientId])
}

enum HttpMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
}

enum MonitorStatus {
  UP
  DOWN
  UNKNOWN
}

enum NotificationType {
  INFO
  ALERT
  REMINDER
  ERROR
  SUCCESS
}

enum CriteriaType {
  STATUS_CODE
  RESPONSE_TIME
  RESPONSE_BODY
}

enum Operator {
  EQUALS
  NOT_EQUALS

  GREATER_THAN
  GREATER_THAN_EQUAL

  LESS_THAN
  LESS_THAN_EQUAL

  CONTAINS
}
