generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  password  String?
  updatedAt DateTime  @updatedAt
  image     String?
  accounts  Account[]
  monitors  Monitor[]
}

model Account {
  id                Int    @id @default(autoincrement())
  provider          String
  providerAccountId String
  userId            Int
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Monitor {
  id              Int            @id @default(autoincrement())
  userId          Int
  name            String
  url             String         @unique
  method          HttpMethod
  status          MonitorStatus  @default(UNKNOWN)
  intervalMinutes Int
  isActive        Boolean        @default(true)
  lastCheckedAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  checkResults    CheckResult[]
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications   Notification[]

  @@index([userId])
}

model CheckResult {
  id           Int      @id @default(autoincrement())
  monitorId    Int
  success      Boolean
  statusCode   Int?
  responseTime Int?
  errorMessage String?
  checkedAt    DateTime @default(now())
  monitor      Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([checkedAt])
}

model Notification {
  id        Int              @id @default(autoincrement())
  monitorId Int
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  monitor   Monitor          @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId])
}


enum HttpMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
}
enum MonitorStatus {
  UP
  DOWN
  UNKNOWN
}

enum NotificationType {
  DOWN
  RECOVERED
  SLOW_RESPONSE
}
